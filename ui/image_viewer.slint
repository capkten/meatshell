import { Theme } from "theme.slint";

export component ImageViewer {
    in property <string> file-name;
    in property <int> index;
    in property <int> total;
    in property <image> preview-image;
    in-out property <float> scale: 1.0;
    in-out property <length> pan-x: 0;
    in-out property <length> pan-y: 0;
    property <bool> panning: false;
    property <length> pan-start-x;
    property <length> pan-start-y;
    in property <string> error-msg;

    callback close();
    callback prev();
    callback next();

    width: 100%;
    height: 100%;

    // Dark semi-transparent overlay
    Rectangle {
        background: #000000cc;
        width: 100%;
        height: 100%;
    }

    iv-focus := FocusScope {
        width: 100%;
        height: 100%;
        key-pressed(e) => {
            if (e.text == Key.Escape) {
                root.close();
                return accept;
            }
            if (e.text == Key.LeftArrow) {
                root.prev();
                return accept;
            }
            if (e.text == Key.RightArrow) {
                root.next();
                return accept;
            }
            return reject;
        }

        // Title bar
        Rectangle {
            y: 0;
            height: 40px;
            background: #00000066;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 8px;
                alignment: space-between;

                Text {
                    text: root.file-name
                        + (root.total > 0 ? "  " + root.index + "/" + root.total : "")
                        + (root.scale > 0 ? "  " + Math.round(root.scale * 100) + "%" : "");
                    color: #e6e8ee;
                    font-size: Theme.fs-md;
                    vertical-alignment: center;
                    overflow: elide;
                    horizontal-stretch: 1;
                }

                Rectangle {
                    width: 28px;
                    height: 28px;
                    background: close-ta.has-hover ? #ffffff22 : transparent;
                    border-radius: Theme.radius-sm;
                    close-ta := TouchArea {
                        clicked => { root.close(); }
                    }
                    Text {
                        text: "\u{e5cd}";
                        font-family: "Material Icons";
                        color: #e6e8ee;
                        font-size: 18px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Error message
        if root.error-msg != "" : Rectangle {
            width: 100%;
            height: 100%;
            Text {
                text: root.error-msg;
                color: #e6e8ee;
                font-size: Theme.fs-lg;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        // Image display with zoom/pan
        if root.error-msg == "" : TouchArea {
            x: 0;
            y: 40px;
            width: root.width;
            height: root.height - 40px;

            scroll-event(event) => {
                if (event.delta-y < 0) {
                    root.scale = Math.min(root.scale * 1.1, 10.0);
                } else {
                    root.scale = Math.max(root.scale / 1.1, 0.1);
                }
                accept
            }

            pointer-event(event) => {
                if (event.kind == PointerEventKind.down && root.scale > 1.0) {
                    root.panning = true;
                    root.pan-start-x = self.mouse-x;
                    root.pan-start-y = self.mouse-y;
                } else if (event.kind == PointerEventKind.up) {
                    if (!root.panning) {
                        // Click without drag: navigate left/right
                        if (self.mouse-x < root.width / 2) {
                            root.prev();
                        } else {
                            root.next();
                        }
                    }
                    root.panning = false;
                }
            }

            moved => {
                if (root.panning) {
                    root.pan-x += self.mouse-x - root.pan-start-x;
                    root.pan-y += self.mouse-y - root.pan-start-y;
                    root.pan-start-x = self.mouse-x;
                    root.pan-start-y = self.mouse-y;
                }
            }

            double-clicked => {
                root.scale = 1.0;
                root.pan-x = 0;
                root.pan-y = 0;
            }

            Image {
                source: root.preview-image;
                image-fit: contain;
                width: (root.width - 120px) * root.scale;
                height: (root.height - 40px) * root.scale;
                x: 60px + root.pan-x;
                y: root.pan-y;
            }
        }
    }
}
